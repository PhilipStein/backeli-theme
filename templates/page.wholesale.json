{
  "sections": {
    "hero_wholesale": {
      "type": "hero",
      "blocks": {
        "heading": {
          "type": "text",
          "settings": {
            "text": "<p>wholesale</p>",
            "width": "fit-content",
            "max_width": "normal",
            "alignment": "center",
            "type_preset": "custom",
            "font": "var(--font-heading--family)",
            "font_size": "4.5rem",
            "line_height": "normal",
            "letter_spacing": "normal",
            "case": "none",
            "wrap": "pretty",
            "text_color": "{{ settings.color_palette.background }}"
          },
          "blocks": {}
        },
        "sub": {
          "type": "text",
          "settings": {
            "text": "<p>Authentic German breads, rolls and pastries — crafted in Germany, enjoyed fresh around the world.</p>",
            "width": "100%",
            "max_width": "normal",
            "alignment": "center",
            "type_preset": "custom",
            "font": "var(--font-body--family)",
            "font_size": "1.25rem",
            "line_height": "normal",
            "letter_spacing": "normal",
            "case": "none",
            "wrap": "pretty",
            "text_color": "{{ settings.color_palette.background }}"
          },
          "blocks": {}
        },
        "cta_btn": {
          "type": "button",
          "settings": {
            "label": "REQUEST INFO",
            "link": "mailto:hello@backeli.com?subject=Wholesale%20Information%20Request",
            "style_class": "button"
          },
          "blocks": {}
        }
      },
      "block_order": ["heading", "sub", "cta_btn"],
      "name": "t:names.hero",
      "settings": {
        "media_type_1": "image",
